<?xml version="1.0"?>
<Container version="2">
  <Name>red-discordbot</Name>
  <Repository>phasecorex/red-discordbot:full</Repository>
  <Registry>https://hub.docker.com/r/phasecorex/red-discordbot/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://forums.unraid.net/topic/87798-support-selfhostersnets-template-repository/</Support>
  <Project>https://github.com/PhasecoreX/docker-red-discordbot</Project>
  <Overview>The newest Red-Discordbot in a convenient multi-arch container &#xD;
&#xD;
&#xD;
&#xD;
How to create a bot account: https://discordpy.readthedocs.io/en/v1.0.1/discord.html#creating-a-bot-account&#xD;
&#xD;
&#xD;
&#xD;
Readme: https://github.com/PhasecoreX/docker-red-discordbot</Overview>
  <Category>Tools:Utilities</Category>
  <WebUI/>
  <TemplateURL>https://raw.githubusercontent.com/selfhosters/unRAID-CA-templates/master/templates/red-discordbot.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/selfhosters/unRAID-CA-templates/master/templates/img/red-discordbot.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>1770955724</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Prefix" Target="PREFIX" Default="" Mode="" Description="The prefix you want Red-DiscordBot to use." Type="Variable" Display="always" Required="true" Mask="false">!</Config>
  <Config Name="Token" Target="TOKEN" Default="" Mode="" Description="The bot token you want Red-DiscordBot to use." Type="Variable" Display="always" Required="true" Mask="true">YOUR_BOT_TOKEN_HERE</Config>
  <Config Name="EXTRA_ARGS" Target="EXTRA_ARGS" Default="" Mode="" Description="" Type="Variable" Display="always" Required="false" Mask="false">--co-owner YOUR_DISCORD_USER_ID_HERE</Config>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="" Type="Variable" Display="advanced" Required="false" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="" Type="Variable" Display="advanced" Required="false" Mask="false">100</Config>
  <Config Name="Data" Target="/data" Default="/mnt/user/appdata/redbot" Mode="rw" Description="" Type="Path" Display="advanced" Required="false" Mask="false">/mnt/user/appdata/redbot</Config>
  <Config Name="Docker Socket" Target="/var/run/docker.sock" Default="/var/run/docker.sock" Mode="rw" Description="Docker socket — required for gsm-autosync to detect container start/stop events." Type="Path" Display="always" Required="true" Mask="false">/var/run/docker.sock</Config>
  <Config Name="DiscordGSM AppData" Target="/discordgsm" Default="/mnt/user/appdata/discordgsm" Mode="rw" Description="Path to DiscordGSM appdata folder. Required for the gsm-autosync cog to read/write servers.db." Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/discordgsm</Config>
</Container>
